# ─────────────────────────────────────────────────────────────
# State-Grounded LLM Honeypot — environment configuration
# Copy to `.env` and adjust. `.env` is git-ignored.
# ─────────────────────────────────────────────────────────────

# --- LLM (Ollama) ---
# Pinned model for reproducibility. Lighter 3B default for weak hardware;
# candidates for stronger machines: qwen2.5:7b, llama3.1:8b
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_HOST=http://ollama:11434

# --- Middleware ---
# Resolve deterministic commands (cd, pwd, mkdir, ls...) from the state
# engine without calling the LLM. true = faster + more consistent.
MIDDLEWARE_FAST_PATH=true
# Inject the live session-state snapshot into the prompt before generation.
MIDDLEWARE_PROMPT_GROUNDING=true
MIDDLEWARE_LOG_LEVEL=INFO
# Per-command event log (SGLH-3). Each line is a JSON event with a `served_by`
# field ("fast-path"|"llm") that the dashboard reads. Point at a path on a
# volume shared with the dashboard. Empty = file output disabled.
MIDDLEWARE_EVENTS_LOG=var/sglh-events.jsonl

# --- Cowrie ---
COWRIE_SSH_PORT=2222
COWRIE_TELNET_PORT=2223

# --- Harness ---
# Where baseline / after results are written (git-ignored).
HARNESS_RESULTS_DIR=harness/results
